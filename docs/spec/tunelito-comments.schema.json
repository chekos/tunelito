{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tunelito.dev/spec/tunelito-comments.schema.json",
  "title": "Tunelito comments index",
  "type": "object",
  "required": [
    "format",
    "version",
    "targetPath",
    "commentsPath",
    "agentStatePath",
    "ok",
    "summary",
    "agentStatus",
    "comments",
    "diagnostics"
  ],
  "properties": {
    "format": {
      "const": "tunelito-comments"
    },
    "version": {
      "const": 2
    },
    "targetPath": {
      "type": ["string", "null"]
    },
    "commentsPath": {
      "type": ["string", "null"]
    },
    "agentStatePath": {
      "type": ["string", "null"]
    },
    "ok": {
      "type": "boolean"
    },
    "summary": {
      "type": "object",
      "required": ["total", "page", "site", "owner", "visitor", "ownerApproved", "pending", "unhandled", "completed"],
      "additionalProperties": false,
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "page": {
          "type": "integer",
          "minimum": 0
        },
        "site": {
          "type": "integer",
          "minimum": 0
        },
        "owner": {
          "type": "integer",
          "minimum": 0
        },
        "visitor": {
          "type": "integer",
          "minimum": 0
        },
        "ownerApproved": {
          "type": "integer",
          "minimum": 0
        },
        "pending": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "unhandled": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "completed": {
          "type": ["integer", "null"],
          "minimum": 0
        }
      }
    },
    "agentStatus": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/agentStatusSnapshot"
        }
      ]
    },
    "comments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "author",
          "authorRole",
          "reviewerId",
          "ownerApproval",
          "scope",
          "quote",
          "body",
          "prefix",
          "suffix",
          "path",
          "pagePath",
          "textStart",
          "textEnd",
          "created",
          "agentStatus"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "author": {
            "type": "string"
          },
          "authorRole": {
            "enum": ["owner", "visitor"]
          },
          "reviewerId": {
            "type": ["string", "null"]
          },
          "ownerApproval": {
            "anyOf": [
              {
                "type": "null"
              },
              {
                "type": "object",
                "required": ["approvedBy", "approvedAt", "fingerprint"],
                "additionalProperties": false,
                "properties": {
                  "approvedBy": {
                    "type": "string"
                  },
                  "approvedAt": {
                    "type": "string"
                  },
                  "fingerprint": {
                    "type": "string"
                  }
                }
              }
            ]
          },
          "scope": {
            "enum": ["page", "site"]
          },
          "quote": {
            "type": "string"
          },
          "body": {
            "type": "string"
          },
          "prefix": {
            "type": "string"
          },
          "suffix": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "pagePath": {
            "type": "string"
          },
          "textStart": {
            "type": ["integer", "null"]
          },
          "textEnd": {
            "type": ["integer", "null"]
          },
          "created": {
            "type": "string"
          },
          "agentStatus": {
            "anyOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/$defs/agentCommentStatus"
              }
            ]
          }
        }
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "code", "message"],
        "properties": {
          "severity": {
            "enum": ["info", "warning", "error"]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "offset": {
            "type": "integer",
            "minimum": 0
          },
          "line": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    }
  },
  "$defs": {
    "agentStatusSnapshot": {
      "type": "object",
      "required": ["version", "updatedAt", "generatedAt", "comments", "summary"],
      "additionalProperties": false,
      "properties": {
        "version": {
          "const": 1
        },
        "updatedAt": {
          "type": ["string", "null"]
        },
        "generatedAt": {
          "type": "string"
        },
        "comments": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/agentCommentStatus"
          }
        },
        "summary": {
          "type": "object",
          "required": ["total", "pending", "unhandled", "completed", "byStatus"],
          "additionalProperties": false,
          "properties": {
            "total": {
              "type": "integer",
              "minimum": 0
            },
            "pending": {
              "type": "integer",
              "minimum": 0
            },
            "unhandled": {
              "type": "integer",
              "minimum": 0
            },
            "completed": {
              "type": "integer",
              "minimum": 0
            },
            "byStatus": {
              "type": "object",
              "additionalProperties": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        }
      }
    },
    "agentCommentStatus": {
      "type": "object",
      "required": ["id", "status", "label", "tone", "done", "todo", "summary", "filesChanged", "updatedAt", "completedAt", "claim"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "tone": {
          "type": "string"
        },
        "done": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "todo": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "summary": {
          "type": "string"
        },
        "filesChanged": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updatedAt": {
          "type": "string"
        },
        "completedAt": {
          "type": ["string", "null"]
        },
        "claim": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "type": "object",
              "required": ["id", "owner", "expiresAt", "active"],
              "additionalProperties": false,
              "properties": {
                "id": {
                  "type": "string"
                },
                "owner": {
                  "type": "string"
                },
                "expiresAt": {
                  "type": "string"
                },
                "active": {
                  "type": "boolean"
                }
              }
            }
          ]
        }
      }
    }
  },
  "additionalProperties": false
}
