{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Tunelito",
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#0f766e",
    "light": "#14b8a6",
    "dark": "#0f766e"
  },
  "logo": {
    "light": "/logo-light.svg",
    "dark": "/logo-dark.svg"
  },
  "navigation": {
    "groups": [
      {
        "group": "Get started",
        "icon": "rocket",
        "pages": [
          "index",
          "quickstart",
          "tutorial",
          "iphone-home-screen",
          "pre-call-checklist"
        ]
      },
      {
        "group": "Core concepts",
        "icon": "layers",
        "pages": [
          "how-it-works",
          "comments",
          "agent-worker",
          "agent-setup",
          "sharing-safely"
        ]
      },
      {
        "group": "Reference",
        "icon": "square-terminal",
        "pages": [
          "cli",
          "examples",
          "troubleshooting"
        ]
      },
      {
        "group": "Maintainers",
        "icon": "wrench",
        "pages": [
          "maintainers",
          "agent-workflows"
        ]
      }
